# AWS credentials. For DynamoDB Local, any non-empty values work.
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Optional, for temporary credentials (STS / SSO).
# AWS_SESSION_TOKEN=

# Required region.
AWS_REGION=us-east-1

# Optional: use an AWS profile from ~/.aws/credentials instead of explicit keys.
# AWS_PROFILE=default

# Optional: point at DynamoDB Local instead of AWS.
# DYNAMODB_ENDPOINT_URL=http://localhost:8000
